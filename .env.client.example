# ========================================================================
# tmuxd CLIENT configuration
# ========================================================================
#
# A client runs on YOUR machine (laptop, server, container) and exposes
# its local tmux to a remote tmuxd server. It's an OUTBOUND WebSocket
# connection — the client does not open any inbound port.
#
# Two-token trust model — see docs/identity-model.md:
#
#   1. Server token: the server's TMUXD_SERVER_TOKEN. The server admin
#      gives it to you. It authorizes your client to use this server at
#      all.
#
#   2. User token: YOUR personal token. The server computes
#      namespace = sha256(userToken).slice(0, 16) from it. Use the SAME
#      user token across all your devices that should share an identity
#      (laptop + desktop + phone all under the same namespace), and the
#      same one your `tmuxd login` uses on this server.
#
# Quick start:
#   1. Copy this file to .env at the client repo root
#   2. Fill in the four required values below
#   3. npm run client
#
# This file is for CLIENT machines. The server itself uses .env.example.
# ========================================================================

# ------------------------------------------------------------------------
# Required
# ------------------------------------------------------------------------

# Server base URL. Use https:// in production — client connections
# include both tokens in the URL query string, which is sniffable on
# plain http beyond loopback.
TMUXD_URL=https://tmuxd.example.com

# Trust-circle token. Get this from the server admin. SAME value as the
# server's TMUXD_SERVER_TOKEN.
TMUXD_SERVER_TOKEN=change-me

# Your personal token. The server hashes it into your namespace; never
# leaves your devices.
#
# **Do NOT generate a fresh user token on this client box.** Generate
# ONCE in the CLI on whichever machine you set up first:
#
#     npm run tmuxd -- login --hub <url> --server-token <secret> \
#                            --user-token-generate
#
# Save the printed value, then paste/copy it here on every other
# device — laptop CLI, web UI, additional clients. Different user
# tokens land in different namespaces; if you re-generate per device,
# each client will register under a separate identity and your web/CLI
# session won't see it.
TMUXD_USER_TOKEN=change-me

# ------------------------------------------------------------------------
# Optional
# ------------------------------------------------------------------------

# Stable host identifier. Letters/digits/dot/underscore/dash, ≤ 64 chars.
# Shows up in URLs (/attach/<host>/<session>) and CLI targets
# (`-t <host>:<session>`). Must be unique within your namespace — running
# two clients with the same TMUXD_HOST_ID under the same TMUXD_USER_TOKEN
# is rejected. Defaults to a slug of TMUXD_HOST_NAME.
# TMUXD_HOST_ID=laptop

# Display name shown in the web UI's host list. Cosmetic only.
# TMUXD_HOST_NAME=Alice Laptop

# Override the tmux binary path. Useful for non-standard installs
# (Homebrew on M-series, Nix profiles, custom builds).
# TMUXD_TMUX_PATH=/opt/homebrew/bin/tmux

# ------------------------------------------------------------------------
# What you do NOT set on a client
# ------------------------------------------------------------------------
# These belong on the SERVER only (in its .env), not here:
#   - TMUXD_RELAY         (server-side switch)
#   - HOST, PORT          (client is outbound, no inbound listener)
#   - JWT_SECRET          (client does not sign JWTs)
#   - TMUXD_HOME          (client has no persisted state)
#   - TMUXD_AUDIT_DISABLE (client has no audit log)
