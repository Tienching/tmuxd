# Required: password for web login. No default — server refuses to start without this.
TMUXD_PASSWORD=change-me

# Optional: bind address (default 127.0.0.1). Set 0.0.0.0 to expose to LAN.
HOST=127.0.0.1

# Optional: HTTP port (default 7681).
PORT=7681

# Optional: JWT secret (auto-generated and persisted to .tmuxd/jwt-secret if not set).
# JWT_SECRET=
