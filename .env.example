# ========================================================================
# tmuxd HUB configuration
# ========================================================================
#
# This file configures a tmuxd HUB. Agents on other machines use a
# different template — see .env.agent.example.
#
# tmuxd uses a TWO-TOKEN trust model — see docs/identity-model.md.
#
#   1. Server token (this file): the trust-circle key. Anyone who knows
#      it can use this hub as a relay. Configure it here on the hub;
#      every client (web/CLI/agent) presents it on connect.
#
#   2. User token (per-user, NOT in this file): each user invents or
#      generates one personal token and keeps it private. The hub does
#      NOT store user tokens; it derives namespace = sha256(userToken)
#      and uses that as the user's identity tag.
#
# Add a user → tell them the server token (1) and have them generate or
# pick a user token (2). No hub config change needed for new users or
# new agents.
# ========================================================================
#
# Pick a deployment mode (full guide: docs/deployment-modes.md):
#
#   ┌─────────────────────────────────────────────────────────────────┐
#   │ Want anyone besides yourself to use this hub?                   │
#   │ ├── No  → Mode A: HOST=127.0.0.1, leave TMUXD_HUB_ONLY unset    │
#   │ └── Yes → Should the hub box itself host tmux sessions?         │
#   │           ├── Yes → Mode B: HOST=0.0.0.0, TMUXD_HUB_ONLY unset  │
#   │           │        (hub's local tmux is visible to ALL users)   │
#   │           └── No  → Mode C: HOST=0.0.0.0, TMUXD_HUB_ONLY=1 ⭐   │
#   │                     (recommended multi-user shape)              │
#   └─────────────────────────────────────────────────────────────────┘
#
# Mode D (public hub, server token publicly known) uses the same env
# as C; the difference is operational, not config. It is rarely the
# right answer — read docs/deployment-modes.md before considering it.
# ========================================================================

# Required: shared trust-circle token. Treat like a team password.
# Generate: openssl rand -hex 32
TMUXD_SERVER_TOKEN=change-me

# ------------------------------------------------------------------------
# Hub-only mode
# ------------------------------------------------------------------------
# When TMUXD_HUB_ONLY=1, the hub refuses to host tmux sessions itself
# (every local route returns 403; the local host is hidden from every
# namespace). Operators run agents from elsewhere; the hub is purely a
# routing layer. Recommended for any multi-user deployment.
# TMUXD_HUB_ONLY=1

# ------------------------------------------------------------------------
# Network
# ------------------------------------------------------------------------
# Bind address. 127.0.0.1 = local only (default). 0.0.0.0 = all NICs.
HOST=127.0.0.1

# HTTP port.
PORT=7681

# ------------------------------------------------------------------------
# JWT secret
# ------------------------------------------------------------------------
# Auto-generated and persisted to .tmuxd/jwt-secret if not set.
# Override only if you need to share JWT-signing keys across multiple
# hub replicas behind a load balancer.
# JWT_SECRET=

# ------------------------------------------------------------------------
# Audit log
# ------------------------------------------------------------------------
# Structured single-line JSON on stderr. Events: login_success,
# login_failure, auth_failure, agent_register, agent_rejected,
# agent_disconnect, ws_attach. Set this only for tests that want
# clean stderr — production should leave it on.
# TMUXD_AUDIT_DISABLE=1

# ------------------------------------------------------------------------
# tmux binary
# ------------------------------------------------------------------------
# Override the tmux binary the agent / local-tmux paths invoke.
# Useful for hosts where tmux is at a non-standard location.
# TMUXD_TMUX_PATH=/opt/tmux/bin/tmux
