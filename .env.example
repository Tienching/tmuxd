# Required: shared web-login token. There is one auth concept; single-user
# is the no-namespace special case of the multi-user form.
#
#   - Bare token  →  bare login (`abc123`) lands the user in the
#                    `default` namespace. Use this for single-user
#                    deployments.
#   - With suffix →  multi-user login (`abc123:alice`) stamps the JWT
#                    with namespace `alice`. The server isolates every
#                    host/session/ticket by it.
#
# IMPORTANT: namespace is a per-user *label*, not an auth boundary against
# anyone holding the base token. Eviction = rotate TMUXD_TOKEN AND reissue
# every per-user agent token.
TMUXD_TOKEN=change-me

# Hub-only mode. When set to 1/true, every local-tmux route returns 403 and
# the local host is hidden from every namespace's host list. Sysadmins who
# want to use tmux on this box should SSH in directly. Recommended for any
# multi-user deployment.
# TMUXD_HUB_ONLY=1

# Optional: bind address (default 127.0.0.1). Set 0.0.0.0 to expose to LAN.
HOST=127.0.0.1

# Optional: HTTP port (default 7681).
PORT=7681

# Optional: JWT secret (auto-generated and persisted to .tmuxd/jwt-secret if not set).
# JWT_SECRET=

# Optional: hub/agent mode. Per-host token bindings on the hub.
# Format: comma-separated entries of either
#   <namespace>/<hostId>=<token>  (preferred for hub mode)
# or
#   <hostId>=<token>              (single-user form, binds into the default namespace)
#
# Hub-mode example with two users:
#   TMUXD_AGENT_TOKENS=alice/laptop=replace-with-a-long-random-token,bob/desktop=replace-with-another-long-random-token
#
# TMUXD_AGENT_TOKENS=workstation=replace-with-a-long-random-agent-token
#
# Single shared-token mode (binds into default namespace):
# TMUXD_AGENT_TOKEN=replace-with-a-long-random-agent-token

# Optional: silence the structured audit log on stderr. Default behavior in
# production is on, with seven event types: login_success, login_failure,
# auth_failure, agent_register, agent_rejected, agent_disconnect, ws_attach.
# See docs/hub-mode.md for field shapes. Only set this for tests that want
# clean stderr.
# TMUXD_AUDIT_DISABLE=1

# Optional: override the tmux binary the agent / local-tmux paths invoke.
# Useful for hosts where tmux is installed at a non-standard location.
# TMUXD_TMUX_PATH=/opt/tmux/bin/tmux

# Migration: TMUXD_PASSWORD and TMUXD_BASE_TOKEN are accepted as deprecated
# aliases for TMUXD_TOKEN, with a startup warning. Please rename to
# TMUXD_TOKEN at your earliest convenience.
