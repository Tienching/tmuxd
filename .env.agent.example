# ========================================================================
# tmuxd AGENT configuration
# ========================================================================
#
# An agent runs on YOUR machine (laptop, server, container) and exposes
# its local tmux to a remote tmuxd hub. It's an OUTBOUND WebSocket
# connection — the agent does not open any inbound port.
#
# Two-token trust model — see docs/identity-model.md:
#
#   1. Server token: the hub's TMUXD_SERVER_TOKEN. The hub admin gives
#      it to you. It authorizes your agent to use this hub at all.
#
#   2. User token: YOUR personal token. The hub computes
#      namespace = sha256(userToken).slice(0, 16) from it. Use the SAME
#      user-token across all your devices that should share an identity
#      (laptop + desktop + phone all under the same namespace), and the
#      same one your `tmuxd login` uses on this hub.
#
# Quick start:
#   1. Copy this file to .env at the agent repo root
#   2. Fill in the four required values below
#   3. npm run agent
#
# This file is for AGENT machines. The hub itself uses .env.example.
# ========================================================================

# ------------------------------------------------------------------------
# Required
# ------------------------------------------------------------------------

# Hub base URL. Use https:// in production — agent connections include
# both tokens in the URL query string, which is sniffable on plain http
# beyond loopback.
TMUXD_HUB_URL=https://hub.example.com

# Trust-circle token. Get this from the hub admin. SAME value as the
# hub's TMUXD_SERVER_TOKEN.
TMUXD_SERVER_TOKEN=change-me

# Your personal token. The hub hashes it into your namespace; never
# leaves your devices. If you don't have one yet, generate via:
#   npm run tmuxd -- login --hub <url> --server-token <secret> \
#                          --user-token-generate
# Save the printed token somewhere safe and re-use it everywhere.
TMUXD_USER_TOKEN=change-me

# ------------------------------------------------------------------------
# Optional
# ------------------------------------------------------------------------

# Stable host identifier. Letters/digits/dot/underscore/dash, ≤ 64 chars.
# Shows up in URLs (/attach/<host>/<session>) and CLI targets
# (`-t <host>:<session>`). Must be unique within your namespace — running
# two agents with the same TMUXD_HOST_ID under the same TMUXD_USER_TOKEN
# is rejected. Defaults to a slug of TMUXD_HOST_NAME.
# TMUXD_HOST_ID=laptop

# Display name shown in the web UI's host list. Cosmetic only.
# TMUXD_HOST_NAME=Alice Laptop

# Override the tmux binary path. Useful for non-standard installs
# (Homebrew on M-series, Nix profiles, custom builds).
# TMUXD_TMUX_PATH=/opt/homebrew/bin/tmux

# ------------------------------------------------------------------------
# What you do NOT set on an agent
# ------------------------------------------------------------------------
# These belong on the HUB only (in its .env), not here:
#   - TMUXD_HUB_ONLY    (hub-side switch)
#   - HOST, PORT        (agent is outbound, no inbound listener)
#   - JWT_SECRET        (agent does not sign JWTs)
#   - TMUXD_HOME        (agent has no persisted state)
#   - TMUXD_AUDIT_DISABLE (agent has no audit log)
